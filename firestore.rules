rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Utenti: ognuno legge/scrive solo il proprio, il gestore legge tutti
    match /users/{uid} {
      allow read: if request.auth != null &&
                     (request.auth.uid == uid ||
                      request.auth.token.email == 'manager@saladanza.it');
      allow write: if request.auth != null &&
                      (request.auth.uid == uid ||
                       request.auth.token.email == 'manager@saladanza.it');
    }

    // Events e bookings: lettura pubblica, scrittura autenticata
    match /events/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /bookings/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
